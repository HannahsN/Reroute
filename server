require('dotenv').config();
const express = require('express');
const cors = require('cors');

const app = express();
app.use(cors());
app.use(express.json());

app.post('/api/chat', async (req, res) => {
    try {
        const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${process.env.GROQ_API_KEY}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                model: "llama-3.3-70b-versatile",
                messages: req.body.messages
            })
        });

        const data = await response.json();
        
        // If Groq is mad, print why in the terminal!
        if (!response.ok) {
            console.error("❌ Groq Error:", data);
            return res.status(500).json({ error: "Groq rejected the request" });
        }

        res.json(data);
    } catch (err) {
        console.error("❌ Server Crash:", err);
        res.status(500).json({ error: "Server Error" });
    }
});

// The crucial 127.0.0.1 connection fix
app.listen(3000, '127.0.0.1', () => console.log('✅ Server is running on http://127.0.0.1:3000'));
